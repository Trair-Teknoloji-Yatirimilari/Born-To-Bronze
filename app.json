{
  "expo": {
    "name": "Eda",
    "slug": "bronze-cream",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EBD0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bronzecream.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Eda uygulamasının kameranıza erişmesine izin verin",
        "NSPhotoLibraryUsageDescription": "Eda uygulamasının fotoğraflarınıza erişmesine izin verin",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "11"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#F4EBD0"
      },
      "package": "com.bronzecream.app",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Eda uygulamasının kameranıza erişmesine izin verin"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "atakan-development"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2043acd9-9368-4c64-b5c8-cecf0a1b52bb"
      }
    }
  }
}
